#! /bin/sh

# ==========================================
# Configuraciï¿½n del Entorno (bspc)
# ==========================================

bspc monitor -d 1 2 3 4 5 6 # 7 8 9

# Apariencia
bspc config border_width 0
bspc config window_gap 20
bspc config split_ratio 0.5
bspc config borderless_monocle true
bspc config gapless_monocle true

# Reglas de ventanas especï¿½ficas
bspc rule -a Gimp desktop='^8' state=floating follow=on
bspc rule -a Chromium desktop='^2'
bspc rule -a mplayer2 state=floating
bspc rule -a Kupfer.py focus=on
bspc rule -a Screenkey manage=off

# ==========================================
# Autoarranque de Aplicaciones (Daemons)
# ==========================================

# Gestor de atajos de teclado (Solo iniciar si no existe)
pgrep -x sxhkd >/dev/null || sxhkd &

# Portapapeles y resoluciï¿½n de la Mï¿½quina Virtual (KVM)
#pgrep -x spice-vdagent >/dev/null || spice-vdagent &

pgrep -x vmware-user-suid-wrapper >/dev/null || vmware-user-suid-wrapper &

# Compositor visual (Picom) - Solo iniciar si no existe
pgrep -x picom >/dev/null || picom &

# Barra de estado (Asegï¿½rate de que launch.sh tenga un "killall -q polybar" adentro)
$HOME/.config/polybar/launch.sh &

# ==========================================
# Ajustes rï¿½pidos de una sola ejecuciï¿½n
# ==========================================

# Fondo de pantalla
nitrogen --restore &

# Compatibilidad para Java (pantallas grises)
wmname LG3D &

# Soluciï¿½n para el cursor (forzar la flecha normal)
xsetroot -cursor_name left_ptr &

# Configuraciï¿½n de teclado
setxkbmap -layout us -variant alt-intl

# Resoluciï¿½n de pantalla de la VM
xrandr --output Virtual-1 --auto
